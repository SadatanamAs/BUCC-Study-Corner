# Base URL of the deployed backend API.
#
# For local development, copy this file to `.env.local` and keep the
# localhost default below:
#   cp .env.example .env.local
#
# For production deployment on Vercel, set this same variable in the
# project's Environment Variables panel (NOT in a committed file):
#   VITE_API_BASE_URL = https://<your-server>.vercel.app/api
#
# This file is documentation only. `.env` and `.env.local` are
# git-ignored so secrets stay out of the repo.
VITE_API_BASE_URL=http://localhost:5000/api

# (Optional) Admin bootstrap key, used by the /login?role=admin flow.
# Set this on the frontend Vercel project to the same value as the
# server's ADMIN_BOOTSTRAP_TOKEN. Leave unset to disable UI admin
# bootstrap — admins must register via curl in that case.
VITE_ADMIN_BOOTSTRAP_KEY=