# Port number for the backend Express server
PORT=5001

# MongoDB Connection String
# - For Local MongoDB: mongodb://localhost:27017/study_corner
# - For MongoDB Atlas: Replace <PASSWORD> with your MongoDB user password
MONGO_URI=mongodb+srv://corner_devs2026:<PASSWORD>@buccstudyconner.rr7ipn6.mongodb.net/study_corner?retryWrites=true&w=majority&appName=BUCCStudyConner

# Secret key used for signing JWT tokens
JWT_SECRET=your_jwt_secret_key_here

# Node environment mode (e.g., development, production)
NODE_ENV=development

# Shared secret for the optional `departmentReference` field on signup.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When set, a user who includes the matching value in `departmentReference`
# at signup is created as `admin` instead of `user`.
# Leave UNSET to disable admin creation entirely.
ADMIN_BOOTSTRAP_TOKEN=
